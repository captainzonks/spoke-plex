# ==============================================================================
# PLEX MODULE - ENVIRONMENT VARIABLES
# ==============================================================================
# Description: Module-specific environment defaults for spoke-plex
# Author: Matt Barham
# Created: 2026-02-12
# Modified: 2026-04-21
# Version: 1.1.2
# Host: Your Server
# ==============================================================================
# Type: Template
# Security Level: MEDIUM - Contains internal IPs and service endpoints
# Component: module: plex
# ==============================================================================
# Note: This file provides module defaults. Hub base.env variables are merged
#       automatically by Spoke. Site-specific overrides go in modules.yml.
# ==============================================================================

#### IMAGES

PLEX_IMAGE=lscr.io/linuxserver/plex:version-1.43.1.10611-1e34174b1
TAUTULLI_IMAGE=ghcr.io/tautulli/tautulli:v2.17.0

#### NETWORK

PLEX_IP=192.168.35.83
PLEX_PORT=32400
PLEX_URL=https://plex.${DOMAIN}

TAUTULLI_IP=192.168.35.87
TAUTULLI_PORT=8941

#### DATA PATHS (adjust to your media locations)

PLEX_DATA_DIR=${APPDATA_DIR}/plex
MEDIA_DIR=/mnt/media
MOVIES_DIR=${MEDIA_DIR}/movies
TV_DIR=${MEDIA_DIR}/tv
MUSIC_DIR=${MEDIA_DIR}/music
PLEX_DOWNLOADS_DIR=/mnt/storage/plex_downloads
